#include <iostream>
using namespace std;

class Product {
private:
    string productName;
    double price;
    int quantity;

public:
    static int totalProducts;

    void getData() {
        cout << "Product Name: ";
        cin >> productName;

        cout << "Price: ";
        cin >> price;

        cout << "Quantity: ";
        cin >> quantity;

        if (price <= 0 || quantity <= 0) {
            cout << "Invalid Price or Quantity!\n";
            price = 0;
            quantity = 0;
        }

        totalProducts++;
    }

    double calculateTotal() {
        return price * quantity;
    }

    void display() {
        cout << "\nProduct: " << productName
             << "\nPrice: " << price
             << "\nQuantity: " << quantity
             << "\nTotal: " << calculateTotal() << endl;
    }
};

int Product::totalProducts = 0;

int main() {
    int n;
    double grandTotal = 0;

    cout << "Enter number of products: ";
    cin >> n;

    Product p[100];

    for (int i = 0; i < n; i++)
        p[i].getData();

    for (int i = 0; i < n; i++) {
        p[i].display();
        grandTotal += p[i].calculateTotal();
    }

    cout << "\nGrand Total Bill = Rs." << grandTotal;
    cout << "\nTotal Products = " << Product::totalProducts;

    return 0;
}
