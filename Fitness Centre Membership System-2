#include <iostream>
using namespace std;

class Member {
private:
    int memberID;
    string name, planType;
    double fee;

public:
    static int activeMembers;

    void assignPlan() {
        cout << "Member ID: ";
        cin >> memberID;

        cout << "Name: ";
        cin.ignore();
        getline(cin, name);

        cout << "Plan (Basic/Premium/VIP): ";
        cin >> planType;

        if (planType == "Basic")
            fee = 1000;
        else if (planType == "Premium")
            fee = 2000;
        else if (planType == "VIP")
            fee = 3000;
        else {
            cout << "Invalid Plan!\n";
            fee = 0;
        }

        activeMembers++;
    }

    void display() {
        cout << "\nID: " << memberID
             << "\nName: " << name
             << "\nPlan: " << planType
             << "\nFee: Rs." << fee << endl;
    }
};

int Member::activeMembers = 0;

int main() {
    int n;
    cout << "Enter number of members: ";
    cin >> n;

    Member m[100];

    for (int i = 0; i < n; i++)
        m[i].assignPlan();

    for (int i = 0; i < n; i++)
        m[i].display();

    cout << "\nTotal Active Members: " << Member::activeMembers;
    return 0;
}
