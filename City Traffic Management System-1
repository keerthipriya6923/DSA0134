#include <iostream>
using namespace std;
class Violation {
private:
    string vehicleNumber, ownerName, violationType;
    double fineAmount;
public:
    static int totalViolations;
    void input() {
        cout << "Vehicle Number: ";
        cin >> vehicleNumber;
        cout << "Owner Name: ";
        cin.ignore();
        getline(cin, ownerName);
        cout << "Violation Type (SignalJump/NoHelmet/Overspeed): ";
        cin >> violationType;
        calculateFine();
        totalViolations++;
    }
    void calculateFine() {
        if (violationType == "SignalJump")
            fineAmount = 1000;
        else if (violationType == "NoHelmet")
            fineAmount = 500;
        else if (violationType == "Overspeed")
            fineAmount = 1500;
        else {
            fineAmount = 0;
            cout << "Invalid Violation Type!\n";
        }
    }

    void display() {
        cout << "\nVehicle No: " << vehicleNumber
             << "\nOwner: " << ownerName
             << "\nViolation: " << violationType
             << "\nFine: Rs." << fineAmount << endl;
    }
};
int Violation::totalViolations = 0;
int main() {
    int n;
    cout << "Enter number of violations: ";
    cin >> n;
    Violation v[100];
    for (int i = 0; i < n; i++)
        v[i].input();
    cout << "\nViolation Reports\n";
    for (int i = 0; i < n; i++)
        v[i].display();
    cout << "\nTotal Violations: " << Violation::totalViolations;
    return 0;
}
